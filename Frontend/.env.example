# SocialOS Frontend Environment Variables
# Copy this file to .env.local for local development
# For AWS Amplify deployment, set these in Amplify Console > Environment variables

# ============================================
# REQUIRED: Backend API Configuration
# ============================================
NEXT_PUBLIC_API_URL=
# For local development: https://localhost:3443/api

# ============================================
# REQUIRED: User Configuration (Demo Mode)
# ============================================
NEXT_PUBLIC_USER_ID=demo-user-123
# Replace with actual user ID or implement proper authentication

# ============================================
# OPTIONAL: NextAuth Configuration
# ============================================
# NEXTAUTH_URL=https://your-app-url.amplifyapp.com
# NEXTAUTH_SECRET=your-secret-key-here
# Generate secret with: openssl rand -base64 32

# ============================================
# OPTIONAL: Google OAuth
# ============================================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# OPTIONAL: AWS Bedrock (AI Features)
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================
# OPTIONAL: Analytics
# ============================================
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id
